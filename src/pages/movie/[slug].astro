---
import { ArrowLeft, Calendar, Clock, Play, Star, Users } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieActions } from "@/components/LocalMovieActions";
import { episodeWatchKey } from "@/lib/episodes";
import { displayEpisodeServerName, getMovie, movieDetailCachePolicy } from "@/lib/ophim";
import { getDisplayRating, proxiedImage, stripHtml } from "@/lib/utils";

const slug = Astro.params.slug || "";
const movie = await getMovie(slug);
const movieCache = movieDetailCachePolicy(movie);
Astro.response.headers.set("X-Film-Bluesia-Movie-Cache-Class", movieCache.cacheClass);
const firstEp = movie.episodes[0]?.serverData[0];
const heroImage = movie.thumb || movie.poster;
const posterImage = movie.poster || movie.thumb;
const title = `Bluesia Cinema - ${movie.originName || movie.name}`;
const description = stripHtml(movie.content) || "Góc nhỏ của người đam mê phim";
const metaImage = movie.thumb || movie.poster || "/icon-512.png";
const displayRating = getDisplayRating(movie);
---

<BaseLayout title={title} description={description} image={metaImage} type="video.movie">
  <article>
    <section class="relative min-h-[560px] overflow-hidden">
      {heroImage && (
        <picture>
          <source media="(min-width: 640px)" srcset={proxiedImage(heroImage, "backdrop-desktop")} />
          <img
            src={proxiedImage(heroImage, "backdrop-mobile")}
            alt={movie.name}
            class="absolute inset-0 h-full w-full object-cover opacity-60"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </picture>
      )}
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-[#07090f]/80 to-[#07090f]"></div>
      <div class="relative z-10 px-4 pb-8 pt-5">
        <a href="/" class="grid h-11 w-11 place-items-center rounded-full bg-black/50 text-white backdrop-blur">
          <ArrowLeft className="h-5 w-5" />
        </a>
        <div class="mt-10 flex gap-4">
          <div class="w-36 shrink-0 overflow-hidden rounded-3xl bg-zinc-900 shadow-2xl ring-1 ring-white/10">
            {posterImage && (
              <picture>
                <source media="(min-width: 640px)" srcset={proxiedImage(posterImage, "poster-desktop")} />
                <img src={proxiedImage(posterImage, "poster-mobile")} alt={movie.name} class="aspect-[2/3] h-full w-full object-cover" loading="lazy" decoding="async" />
              </picture>
            )}
          </div>
          <div class="min-w-0 flex-1 pt-4">
            {displayRating && (
              <div class="mb-3 inline-flex items-center gap-1 rounded-lg bg-black/50 px-2.5 py-1 text-xs font-bold text-gold backdrop-blur">
                <Star className="h-3.5 w-3.5 fill-gold" /> {displayRating.text}
              </div>
            )}
            <h1 class="text-3xl font-black leading-tight tracking-tight">{movie.name}</h1>
            <p class="mt-2 line-clamp-2 text-sm italic text-zinc-300">{movie.originName}</p>
            <div class="mt-4 flex flex-wrap gap-2 text-xs text-zinc-300">
              {movie.year && <span class="inline-flex items-center gap-1 rounded-lg bg-white/10 px-2.5 py-1"><Calendar className="h-3.5 w-3.5" /> {movie.year}</span>}
              {movie.time && <span class="inline-flex items-center gap-1 rounded-lg bg-white/10 px-2.5 py-1"><Clock className="h-3.5 w-3.5" /> {movie.time}</span>}
              {movie.episodeCurrent && <span class="rounded-lg bg-white/10 px-2.5 py-1">{movie.episodeCurrent}</span>}
              {movie.quality && <span class="rounded-lg bg-gold px-2.5 py-1 font-black text-black">{movie.quality}</span>}
            </div>
          </div>
        </div>
        <div class="mt-6 grid gap-3">
          <a href={`/watch/${movie.slug}${firstEp ? `?ep=${encodeURIComponent(episodeWatchKey(firstEp, 0))}` : ""}`} class="inline-flex items-center justify-center gap-2 rounded-2xl bg-gold px-5 py-4 text-base font-black text-black shadow-glow transition hover:scale-[1.01]">
            <Play className="h-5 w-5 fill-black" /> Xem phim
          </a>
          <MovieActions client:load movie={movie} />
        </div>
      </div>
    </section>

    <section class="px-4 pb-6">
      <div class="flex flex-wrap gap-2">
        {movie.categoryList?.map((item) => <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs text-zinc-300">{item.name}</span>)}
        {movie.countryList?.map((item) => <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs text-zinc-300">{item.name}</span>)}
      </div>

      <h2 class="mt-8 text-xl font-black">Nội dung</h2>
      <p class="mt-3 text-sm leading-7 text-zinc-300">{stripHtml(movie.content) || "Chưa có mô tả."}</p>

      {movie.actor?.length ? (
        <div class="mt-6 rounded-3xl bg-white/5 p-4 ring-1 ring-white/10">
          <h3 class="mb-3 inline-flex items-center gap-2 text-sm font-bold text-zinc-100"><Users className="h-4 w-4 text-gold" /> Diễn viên</h3>
          <p class="text-sm leading-7 text-zinc-300">{movie.actor.slice(0, 12).join(", ")}</p>
        </div>
      ) : null}

      {movie.episodes.length ? (
        <div class="mt-8">
          <h2 class="text-xl font-black">Tập phim</h2>
          {movie.episodes.map((server, serverIndex) => (
            <div class="mt-4 rounded-3xl bg-white/5 p-4 ring-1 ring-white/10">
              <h3 class="mb-3 text-sm font-bold text-zinc-300">{displayEpisodeServerName(server.serverName)}</h3>
              <div class="grid grid-cols-4 gap-2 sm:grid-cols-6">
                {server.serverData.map((ep, epIndex) => (
                  <a href={`/watch/${movie.slug}?server=${serverIndex}&ep=${encodeURIComponent(episodeWatchKey(ep, epIndex))}`} class="rounded-xl bg-white/10 px-3 py-2 text-center text-xs font-bold text-white transition hover:bg-gold hover:text-black">
                    {ep.name || epIndex + 1}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}
    </section>
  </article>
</BaseLayout>

---
import { X } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieCard } from "@/components/MovieCard";
import { SearchSuggest } from "@/components/SearchSuggest";
import { createReturnToPath } from "@/lib/navigation";
import { searchMovies } from "@/lib/ophim";

const q = Astro.url.searchParams.get("q") || "";
const page = Math.max(1, Number(Astro.url.searchParams.get("page") || "1"));
const returnTo = createReturnToPath(Astro.url.pathname, Astro.url.search);
const data = q ? await searchMovies(q, page, 30) : { title: "Tìm kiếm", items: [], page };
---

<BaseLayout title={`${q ? data.title : "Tìm kiếm"} - Bluesia Cinema`}>
  <header class="sticky top-0 z-40 border-b border-white/5 bg-[#07090f]/90 px-4 py-4 backdrop-blur-xl">
    <div class="flex items-center gap-3">
      <SearchSuggest client:load initialQuery={q} autoFocus />
      <a href="/" class="grid h-12 w-12 place-items-center rounded-full border border-white/10 bg-white/10 text-zinc-300">
        <X className="h-5 w-5" />
      </a>
    </div>
  </header>

  <section class="px-4 pt-6">
    <h1 class="text-3xl font-black tracking-tight">{q ? data.title : "Bạn muốn xem gì?"}</h1>
    <p class="mt-1 text-sm text-zinc-400">Nhập tên phim, tên gốc hoặc từ khóa để tìm nhanh.</p>
  </section>

  {data.items.length > 0 ? (
    <section class="grid grid-cols-3 gap-3 px-4 pt-5 sm:grid-cols-4">
      {data.items.map((movie) => <MovieCard movie={movie} compact returnTo={returnTo} />)}
    </section>
  ) : q ? (
    <div class="mx-4 mt-8 rounded-3xl border border-dashed border-white/15 bg-white/5 p-8 text-center text-sm text-zinc-400">Không tìm thấy kết quả phù hợp.</div>
  ) : null}
</BaseLayout>

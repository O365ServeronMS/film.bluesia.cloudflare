---
import { ArrowLeft, ExternalLink, ListVideo } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { HlsVideo } from "@/components/HlsVideo";
import { IframePlayerFacade } from "@/components/IframePlayerFacade";
import { WatchRecorder } from "@/components/WatchRecorder";
import { episodeWatchKey, findEpisodeByWatchKey } from "@/lib/episodes";
import { hrefWithNavSource, inferNavSourceFromMovie, navSourceFromSearchParams } from "@/lib/navigation";
import { displayEpisodeServerName, getMovie } from "@/lib/ophim";
import { proxiedImage } from "@/lib/utils";

const vidsrcHosts = new Set(["vsembed.ru", "vsembed.su", "vidsrc-embed.ru", "vidsrc-embed.su", "vidsrcme.su", "vsrc.su"]);
const slug = Astro.params.slug || "";
const movie = await getMovie(slug);
const serverIndex = Math.max(0, Number(Astro.url.searchParams.get("server") || "0"));
const server = movie.episodes[serverIndex] || movie.episodes[0];
const epKey = Astro.url.searchParams.get("ep") || undefined;
const episode = findEpisodeByWatchKey(server, epKey);
const embed = episode?.linkEmbed;
const m3u8 = episode?.linkM3u8;
const requestedPlayer = String(Astro.url.searchParams.get("player") || "").toLowerCase();
const forceEmbed = requestedPlayer === "embed";
const forceHls = requestedPlayer === "hls";
const userAgent = Astro.request.headers.get("user-agent") || "";
const mobileUA = /android|iphone|ipad|ipod|mobile|iemobile|opera mini|webos/i.test(userAgent);

function mobileVidsrcHost() {
  const host = String(process.env.VSEMBED_MOBILE_EMBED_HOST || "vsembed.su").trim().toLowerCase();
  return vidsrcHosts.has(host) ? host : "vsembed.su";
}

function resolveEmbedUrl(src: string | undefined) {
  if (!src) return undefined;
  try {
    const url = new URL(src);
    if (!vidsrcHosts.has(url.hostname)) return src;
    const mirror = String(Astro.url.searchParams.get("mirror") || "").trim().toLowerCase();
    if (vidsrcHosts.has(mirror)) {
      url.hostname = mirror;
    } else if (mobileUA) {
      url.hostname = mobileVidsrcHost();
    }
    if (mobileUA) url.searchParams.set("autoplay", "0");
    return url.toString();
  } catch {
    return src;
  }
}

const playerEmbed = resolveEmbedUrl(embed);
const useEmbedPlayer = Boolean(playerEmbed) && (forceEmbed || (mobileUA && !forceHls));
const title = `Watching - ${movie.originName || movie.name}`;
const playerPoster = movie.thumb || movie.poster ? proxiedImage(movie.thumb || movie.poster, "backdrop-desktop") : undefined;
const navSourceKey = navSourceFromSearchParams(Astro.url.searchParams) || inferNavSourceFromMovie(movie);
const detailHref = hrefWithNavSource(`/movie/${movie.slug}`, navSourceKey);

if (playerEmbed || m3u8) {
  console.log("[cache] VIDEO_DIRECT_SOURCE_CONFIRMED", { slug, serverIndex, hasEmbed: Boolean(playerEmbed), hasM3u8: Boolean(m3u8) });
  console.log("[cache] VIDEO_PROXY_NOT_USED", { slug });
}
---

<BaseLayout title={title} description={`Đang xem ${movie.originName || movie.name} trên Bluesia Cinema`} image={movie.thumb || movie.poster || "/icon-512.png"} type="video.movie" navSourceFallback={navSourceKey}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://vsembed.ru" />
    <link rel="preconnect" href="https://vsembed.su" />
    <link rel="preconnect" href="https://img.ophim.live" />
    <link rel="preconnect" href="https://img.ophim.cc" />
    <link rel="dns-prefetch" href="https://vsembed.ru" />
    <link rel="dns-prefetch" href="https://vsembed.su" />
    <script is:inline>
      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a[data-watch-episode-link]") : null;
        if (!(link instanceof HTMLAnchorElement)) return;

        const target = new URL(link.href, window.location.href);
        if (target.origin !== window.location.origin || target.pathname !== window.location.pathname) return;

        event.preventDefault();
        window.location.replace(target.toString());
      }, true);
    </script>
  </Fragment>
  <article class="min-h-screen bg-black">
    <WatchRecorder client:load movie={movie} />
    <header class="watch-header sticky top-0 z-40 flex items-center gap-3 border-b border-white/10 bg-black/90 px-3 py-2 backdrop-blur-xl">
      <a href={detailHref} data-nav-back aria-label={`Quay lại ${movie.name}`} class="watch-header-action grid h-10 w-10 shrink-0 place-items-center rounded-full bg-white/10 text-white">
        <ArrowLeft className="h-5 w-5" />
      </a>
      <div class="watch-header-content min-w-0 flex-1">
        <p class="watch-header-eyebrow text-[10px] font-bold uppercase tracking-[0.16em] text-gold">Đang xem</p>
        <div class="watch-header-copy min-w-0">
          <h1 class="watch-header-title truncate text-base font-black text-white">{movie.name}</h1>
          <p class="watch-header-meta truncate text-xs text-zinc-400">{displayEpisodeServerName(server?.serverName)} - {episode?.name || "Tập phim"}</p>
        </div>
      </div>
      {embed && <a href={embed} target="_blank" rel="noreferrer" aria-label="Mở trình phát trong tab mới" class="watch-header-action grid h-10 w-10 shrink-0 place-items-center rounded-full bg-white/10 text-white"><ExternalLink className="h-5 w-5" /></a>}
    </header>

    <section class="aspect-video w-full bg-black">
      {!useEmbedPlayer && m3u8 ? (
        <HlsVideo client:only="react" src={m3u8} poster={playerPoster} />
      ) : playerEmbed ? (
        <IframePlayerFacade client:load src={playerEmbed} poster={playerPoster} title={`${movie.name} - ${episode?.name || "Tập phim"}`} />
      ) : (
        <div class="grid h-full place-items-center p-6 text-center text-sm text-zinc-400">Không có link xem cho tập này.</div>
      )}
    </section>

    <section class="bg-[#07090f] px-4 py-5">
      <div class="mb-4 flex items-center gap-2 text-lg font-black"><ListVideo className="h-5 w-5 text-gold" /> Danh sách tập</div>
      {movie.episodes.map((sv, svIndex) => (
        <div class="mb-5 rounded-3xl bg-white/5 p-4 ring-1 ring-white/10">
          <h2 class="mb-3 text-sm font-bold text-zinc-300">{displayEpisodeServerName(sv.serverName)}</h2>
          <div class="grid grid-cols-4 gap-2 sm:grid-cols-6">
            {sv.serverData.map((ep, epIndex) => {
              const currentKey = episode ? episodeWatchKey(episode, server?.serverData.indexOf(episode) ?? 0) : "";
              const active = svIndex === serverIndex && (episodeWatchKey(ep, epIndex) === currentKey || (epIndex === 0 && !epKey));
              return (
                <a href={hrefWithNavSource(`/watch/${movie.slug}?server=${svIndex}&ep=${encodeURIComponent(episodeWatchKey(ep, epIndex))}`, navSourceKey)} data-watch-episode-link class={active ? "rounded-xl bg-gold px-3 py-2 text-center text-xs font-black text-black" : "rounded-xl bg-white/10 px-3 py-2 text-center text-xs font-bold text-white transition hover:bg-white/15"}>
                  {ep.name || epIndex + 1}
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </section>
  </article>
</BaseLayout>

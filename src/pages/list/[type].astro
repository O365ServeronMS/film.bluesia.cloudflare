---
import { ChevronLeft, ChevronRight } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieCard } from "@/components/MovieCard";
import { TopBar } from "@/components/TopBar";
import { getList } from "@/lib/ophim";

const type = Astro.params.type || "phim-le";
const page = Math.max(1, Number(Astro.url.searchParams.get("page") || "1"));
const quickCountries = [
  { label: "Âu Mỹ", slug: "au-my" },
  { label: "Hàn Quốc", slug: "han-quoc" }
] as const;
const quickCategories = [{ label: "Phim chiếu rạp", slug: "phim-chieu-rap" }] as const;
const countryFilterableTypes = new Set(["phim-le", "phim-bo", "tv-shows"]);
const categoryFilterableTypes = new Set(["phim-le"]);
const supportsCountryFilter = countryFilterableTypes.has(type);
const supportsCategoryFilter = categoryFilterableTypes.has(type);
const countryParam = String(Astro.url.searchParams.get("country") || "").trim().toLowerCase();
const categoryParam = String(Astro.url.searchParams.get("category") || "").trim().toLowerCase();
const country = supportsCountryFilter && quickCountries.some((item) => item.slug === countryParam) ? countryParam : "";
const category = supportsCategoryFilter && quickCategories.some((item) => item.slug === categoryParam) ? categoryParam : "";
const data = await getList(type, page, 30, country, category);
const currentPage = data.page || page;
const totalPages = data.totalPages;
const groupStart = Math.floor((Math.max(1, currentPage) - 1) / 10) * 10 + 1;
const groupEnd = totalPages ? Math.min(groupStart + 9, totalPages) : groupStart + 9;
const pageNumbers = Array.from({ length: Math.max(0, groupEnd - groupStart + 1) }, (_, index) => groupStart + index);
const activeFilters = { country, category };

function listHref(nextPage: number, filters = activeFilters) {
  const query = new URLSearchParams({ page: String(Math.max(1, nextPage)) });
  if (filters.country) query.set("country", filters.country);
  if (filters.category) query.set("category", filters.category);
  return `/list/${type}?${query.toString()}`;
}
---

<BaseLayout title={`${data.title} - Bluesia Cinema`}>
  <TopBar client:load />
  <section class="px-4 pt-6">
    <h1 class="text-3xl font-black tracking-tight">{data.title}</h1>
    <p class="mt-1 text-sm text-zinc-400">Trang {currentPage}{totalPages ? ` / ${totalPages}` : ""}</p>
  </section>

  {(supportsCountryFilter || supportsCategoryFilter) && (
    <section class="space-y-3 px-4 pt-4">
      {supportsCountryFilter && (
        <div aria-label="Lọc nhanh theo quốc gia">
          <p class="mb-2 text-xs font-bold uppercase tracking-[0.18em] text-zinc-400">Quốc gia</p>
          <div class="flex gap-2 overflow-x-auto pb-1 no-scrollbar">
            <a href={listHref(1, { ...activeFilters, country: "" })} class={`whitespace-nowrap rounded-full px-4 py-2 text-sm font-extrabold ring-1 transition ${!country ? "bg-gold text-black ring-gold" : "bg-white/10 text-zinc-200 ring-white/10"}`}>Tất cả</a>
            {quickCountries.map((item) => (
              <a href={listHref(1, { ...activeFilters, country: item.slug })} class={`whitespace-nowrap rounded-full px-4 py-2 text-sm font-extrabold ring-1 transition ${country === item.slug ? "bg-gold text-black ring-gold" : "bg-white/10 text-zinc-200 ring-white/10"}`}>{item.label}</a>
            ))}
          </div>
        </div>
      )}
      {supportsCategoryFilter && (
        <div aria-label="Lọc nhanh theo nhóm phim">
          <p class="mb-2 text-xs font-bold uppercase tracking-[0.18em] text-zinc-400">Nhóm phim</p>
          <div class="flex gap-2 overflow-x-auto pb-1 no-scrollbar">
            <a href={listHref(1, { ...activeFilters, category: "" })} class={`whitespace-nowrap rounded-full px-4 py-2 text-sm font-extrabold ring-1 transition ${!category ? "bg-gold text-black ring-gold" : "bg-white/10 text-zinc-200 ring-white/10"}`}>Tất cả</a>
            {quickCategories.map((item) => (
              <a href={listHref(1, { ...activeFilters, category: item.slug })} class={`whitespace-nowrap rounded-full px-4 py-2 text-sm font-extrabold ring-1 transition ${category === item.slug ? "bg-gold text-black ring-gold" : "bg-white/10 text-zinc-200 ring-white/10"}`}>{item.label}</a>
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <section class="grid grid-cols-3 gap-3 px-4 pt-5 sm:grid-cols-4">
    {data.items.map((movie, index) => (
      <MovieCard movie={movie} compact headingLevel={2} priority={index < 4} navSourceKey={type} />
    ))}
  </section>

  <nav class="px-4 pt-8" aria-label="Phân trang">
    <div class="flex items-center justify-between gap-3">
      <a href={listHref(Math.max(1, currentPage - 1))} aria-disabled={currentPage <= 1} class="inline-flex items-center gap-2 rounded-2xl bg-white/10 px-4 py-3 text-sm font-bold text-white ring-1 ring-white/10 aria-disabled:pointer-events-none aria-disabled:opacity-40">
        <ChevronLeft className="h-4 w-4" /> Trang trước
      </a>
      <a href={listHref(currentPage + 1)} aria-disabled={totalPages ? currentPage >= totalPages : false} class="inline-flex items-center gap-2 rounded-2xl bg-gold px-4 py-3 text-sm font-black text-black aria-disabled:pointer-events-none aria-disabled:opacity-40">
        Trang sau <ChevronRight className="h-4 w-4" />
      </a>
    </div>
    <div class="mt-4 flex gap-2 overflow-x-auto pb-1 no-scrollbar">
      {pageNumbers.map((pageNumber) => (
        <a href={listHref(pageNumber)} aria-current={pageNumber === currentPage ? "page" : undefined} class={`grid h-11 min-w-11 place-items-center rounded-2xl px-3 text-sm font-black ring-1 transition ${pageNumber === currentPage ? "bg-gold text-black ring-gold shadow-glow" : "bg-white/10 text-zinc-200 ring-white/10 hover:bg-white/15 hover:text-white"}`}>
          {pageNumber}
        </a>
      ))}
    </div>
  </nav>
</BaseLayout>

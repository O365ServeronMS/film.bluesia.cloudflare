---
import { BottomNav } from "@/components/BottomNav";
import "@/src/styles/globals.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  navSourceFallback?: string;
};

const {
  title = "Bluesia Cinema",
  description = "Góc nhỏ của người đam mê phim",
  image = "/icon-512.png",
  type = "website",
  navSourceFallback = ""
} = Astro.props;
const canonical = new URL(Astro.url.pathname + Astro.url.search, "https://film.bluesia.net").toString();
const pathname = Astro.url.pathname;
const search = Astro.url.search;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="vi" data-scroll-behavior="smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07090f" />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Bluesia Cinema" />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <script is:inline>
      document.addEventListener("error", (event) => {
        const image = event.target;
        if (!(image instanceof HTMLImageElement) || !image.matches("img[data-movie-poster]")) return;

        const fallback = image.dataset.fallbackSrc || "";
        const fallbackHref = fallback ? new URL(fallback, window.location.href).href : "";
        if (fallbackHref && image.currentSrc !== fallbackHref && image.src !== fallbackHref) {
          image.dataset.fallbackSrc = "";
          image.src = fallbackHref;
          return;
        }

        image.hidden = true;
        const fallbackNode = image.nextElementSibling;
        if (fallbackNode instanceof HTMLElement && fallbackNode.classList.contains("movie-card-image-fallback")) {
          fallbackNode.hidden = false;
        }
      }, true);

      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a[data-nav-back]") : null;
        if (!(link instanceof HTMLAnchorElement)) return;
        if (link.origin !== window.location.origin) return;

        const target = new URL(link.href, window.location.href);
        const targetPath = safeInternalPath(target.pathname + target.search);
        if (targetPath) {
          return;
        }

        let sameOriginReferrer = false;
        try {
          sameOriginReferrer = Boolean(document.referrer && new URL(document.referrer).origin === window.location.origin);
        } catch {}
        if (sameOriginReferrer && history.length > 1) {
          event.preventDefault();
          history.back();
          return;
        }

        const fallbackReturnTo = currentReturnTo();
        if (fallbackReturnTo) {
          event.preventDefault();
          window.location.assign(fallbackReturnTo);
        }
      }, true);

      const navSourceKeys = new Set(["home", "phim-le", "phim-bo", "tv-shows", "hoat-hinh"]);

      function validNavSource(value) {
        const key = String(value || "").trim();
        return navSourceKeys.has(key) ? key : "";
      }

      function navSourceFromPath(pathname) {
        if (pathname === "/") return "home";
        if (pathname.startsWith("/phim-le")) return "phim-le";
        if (pathname.startsWith("/list/phim-le")) return "phim-le";
        if (pathname.startsWith("/phim-bo")) return "phim-bo";
        if (pathname.startsWith("/list/phim-bo")) return "phim-bo";
        if (pathname.startsWith("/tv-show") || pathname.startsWith("/tv-shows")) return "tv-shows";
        if (pathname.startsWith("/list/tv-shows")) return "tv-shows";
        if (pathname.startsWith("/hoat-hinh")) return "hoat-hinh";
        if (pathname.startsWith("/list/hoat-hinh")) return "hoat-hinh";
        return "";
      }

      function navSourceFromSearch(search) {
        const params = new URLSearchParams(String(search || "").replace(/^\?/, ""));
        return navSourceFromReturnTo(params.get("returnTo")) || validNavSource(params.get("from"));
      }

      function navSourceFromHash(hash) {
        const clean = String(hash || "").replace(/^#/, "");
        if (!clean) return "";
        return validNavSource(new URLSearchParams(clean).get("from"));
      }

      function safeInternalPath(value) {
        const raw = String(value || "").trim();
        if (!raw || !raw.startsWith("/") || raw.startsWith("//") || raw.includes("\\") || /[\u0000-\u001f\u007f]/.test(raw)) return "";
        try {
          const url = new URL(raw, window.location.origin);
          if (url.origin !== window.location.origin) return "";
          return url.pathname + url.search;
        } catch {
          return "";
        }
      }

      function returnToFromSearch(search) {
        return safeInternalPath(new URLSearchParams(String(search || "").replace(/^\?/, "")).get("returnTo"));
      }

      function navSourceFromReturnTo(returnTo) {
        const path = safeInternalPath(returnTo);
        if (!path) return "";
        return navSourceFromPath(new URL(path, window.location.origin).pathname);
      }

      function fallbackReturnToForSource(source) {
        switch (validNavSource(source)) {
          case "phim-le":
            return "/phim-le";
          case "phim-bo":
            return "/phim-bo";
          case "tv-shows":
            return "/tv-show";
          case "hoat-hinh":
            return "/hoat-hinh";
          case "home":
            return "/";
          default:
            return "";
        }
      }

      function currentNavSource() {
        return navSourceFromSearch(window.location.search) || navSourceFromPath(window.location.pathname) || navSourceFromHash(window.location.hash);
      }

      function currentReturnTo() {
        return returnToFromSearch(window.location.search) || safeInternalPath(window.location.pathname + window.location.search) || fallbackReturnToForSource(currentNavSource());
      }

      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a[href]") : null;
        if (!(link instanceof HTMLAnchorElement) || link.hasAttribute("data-nav-back")) return;

        const target = new URL(link.href, window.location.href);
        if (target.origin !== window.location.origin) return;
        if (!target.pathname.startsWith("/movie/") && !target.pathname.startsWith("/watch/")) return;
        if (returnToFromSearch(target.search)) return;

        const legacySource = navSourceFromSearch(target.search) || navSourceFromHash(target.hash);
        const returnTo = fallbackReturnToForSource(legacySource) || currentReturnTo();
        if (!returnTo) return;

        target.searchParams.set("returnTo", returnTo);
        target.searchParams.delete("from");
        if (navSourceFromHash(target.hash)) target.hash = "";
        link.href = target.toString();
      }, true);
    </script>
    {isDev && (
      <script is:inline>
        const NAV_CONTEXT_KEY = "film.bluesia.net:last-nav-section";
        const NAV_PENDING_KEY = "film.bluesia.net:pending-navigation";

        function navDebugLog(message, details) {
          console.debug(`[nav] ${message}`, details || {});
        }

        function navSourceFromSearch(search) {
          const params = new URLSearchParams(String(search || "").replace(/^\?/, ""));
          const returnTo = params.get("returnTo") || "";
          if (returnTo.startsWith("/phim-le") || returnTo.startsWith("/list/phim-le")) return "phim-le";
          if (returnTo.startsWith("/phim-bo") || returnTo.startsWith("/list/phim-bo")) return "phim-bo";
          if (returnTo.startsWith("/tv-show") || returnTo.startsWith("/tv-shows") || returnTo.startsWith("/list/tv-shows")) return "tv-shows";
          if (returnTo.startsWith("/hoat-hinh") || returnTo.startsWith("/list/hoat-hinh")) return "hoat-hinh";
          const key = params.get("from") || "";
          return ["home", "phim-le", "phim-bo", "tv-shows", "hoat-hinh"].includes(key) ? key : "";
        }

        function navActiveFromPath(pathname, search, contextKey) {
          if (pathname === "/") return "home";
          if (pathname.startsWith("/phim-le")) return "phim-le";
          if (pathname.startsWith("/list/phim-le")) return "phim-le";
          if (pathname.startsWith("/phim-bo")) return "phim-bo";
          if (pathname.startsWith("/list/phim-bo")) return "phim-bo";
          if (pathname.startsWith("/tv-show") || pathname.startsWith("/tv-shows")) return "tv-shows";
          if (pathname.startsWith("/list/tv-shows")) return "tv-shows";
          if (pathname.startsWith("/hoat-hinh")) return "hoat-hinh";
          if (pathname.startsWith("/list/hoat-hinh")) return "hoat-hinh";
          if (pathname.startsWith("/search")) return "search";
          if (pathname.startsWith("/movie/") || pathname.startsWith("/watch/")) return navSourceFromSearch(search) || contextKey || "";
          return "";
        }

        function navContextFromPath(pathname) {
          const active = navActiveFromPath(pathname, "", "");
          return active && !["home", "search", "settings"].includes(active) ? active : "";
        }

        if ("scrollRestoration" in history) {
          history.scrollRestoration = "auto";
        }

        document.addEventListener("click", (event) => {
          const link = event.target instanceof Element ? event.target.closest("a[href]") : null;
          if (!(link instanceof HTMLAnchorElement)) return;

          const url = new URL(link.href, window.location.href);
          if (url.origin !== window.location.origin) return;

          navDebugLog("NAV_CLICK_TARGET", { href: url.pathname + url.search, from: window.location.pathname + window.location.search });

          const contextKey = navContextFromPath(url.pathname);
          if (contextKey) sessionStorage.setItem(NAV_CONTEXT_KEY, contextKey);

          if (url.pathname.startsWith("/movie/") || url.pathname.startsWith("/watch/")) {
            sessionStorage.setItem(NAV_PENDING_KEY, JSON.stringify({
              from: window.location.pathname + window.location.search,
              to: url.pathname + url.search,
              time: Date.now()
            }));
          }
        }, true);

        window.addEventListener("pageshow", (event) => {
          const current = window.location.pathname + window.location.search;
          const contextKey = sessionStorage.getItem(NAV_CONTEXT_KEY) || "";
          navDebugLog("NAV_ACTIVE_FROM_PATH", {
            pathname: window.location.pathname,
            active: navActiveFromPath(window.location.pathname, window.location.search, contextKey) || null
          });

          try {
            const pending = JSON.parse(sessionStorage.getItem(NAV_PENDING_KEY) || "null");
            if (pending?.to === current) {
              navDebugLog("HISTORY_PUSH_CONFIRMED", pending);
              sessionStorage.removeItem(NAV_PENDING_KEY);
            }
          } catch {
            sessionStorage.removeItem(NAV_PENDING_KEY);
          }

          if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
            navDebugLog("BACK_RESTORED_ROUTE", { route: current });
          }
        });

        window.addEventListener("popstate", () => {
          navDebugLog("BACK_RESTORED_ROUTE", { route: window.location.pathname + window.location.search });
        });

        window.addEventListener("astro:page-load", () => {
          navDebugLog("NAV_ROUTE_CHANGE", { route: window.location.pathname + window.location.search });
        });
      </script>
    )}
    <script>
      import { initAdaptivePrefetch } from "@/src/client/adaptivePrefetch";

      initAdaptivePrefetch();
    </script>
    <slot name="head" />
  </head>
  <body class="font-sans antialiased">
    <main class="mx-auto min-h-screen w-full max-w-[720px] safe-bottom">
      <slot />
    </main>
    <BottomNav client:load initialPathname={pathname} initialSearch={search} initialSourceFallback={navSourceFallback} />
  </body>
</html>
